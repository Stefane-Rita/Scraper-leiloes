{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pip install -r requirements.txt && python -m playwright install chromium",
  "installCommand": "pip install -r requirements.txt",
  "framework": null,
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "*/5 * * * *"
    }
  ],
  "functions": {
    "api/index.py": {
      "memory": 2048
    }
  }
}

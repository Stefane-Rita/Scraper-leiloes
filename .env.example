# --- Google Planilhas (escolha UMA opção de credenciais) ---

# Opção A: caminho para o JSON da Service Account (recomendado local)
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials/service-account.json

# Opção B: conteúdo do JSON em uma linha (recomendado no Railway)
# GOOGLE_SHEETS_CREDENTIALS_JSON={"type":"service_account",...}

# ID da planilha (parte da URL entre /d/ e /edit)
GOOGLE_SPREADSHEET_ID=seu_id_da_planilha

# Nome da aba (será criada automaticamente se não existir)
GOOGLE_WORKSHEET_NAME=Leilões

# --- Agendador ---
# Intervalo entre atualizações em segundos (300 = 5 minutos)
SCRAPE_INTERVAL_SECONDS=300

# --- Paginação (opcional) ---
COPART_MAX_PAGES=50
SODRE_PAGE_SIZE=100
SODRE_MAX_PAGES=30

# --- Vercel (Cron Job) ---
# Gere um valor aleatório longo; a Vercel envia "Authorization: Bearer <CRON_SECRET>"
CRON_SECRET=coloque_um_token_aleatorio_aqui

# Na Vercel, use paginação menor para caber no tempo da função (ex.: 3 e 5)
# COPART_MAX_PAGES=3
# SODRE_MAX_PAGES=5

# --- Servidor ---
PORT=8000
